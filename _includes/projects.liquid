<div class="col">
  <article class="card project-card h-100">
    {% if project.img %}
      {% include figure.liquid loading="lazy" path=project.img sizes="(min-width: 768px) 520px, 100vw" alt=project.title class="card-img-top" %}
    {% else %}
      <div class="project-card__placeholder" aria-hidden="true"><i class="fa-solid fa-diagram-project"></i></div>
    {% endif %}
    <div class="card-body">
      <h3 class="card-title">{{ project.title }}</h3>
      <p class="card-text">{{ project.description }}</p>
      {% if project.contribution %}
        <p class="project-card__contribution"><strong>Contribution:</strong> {{ project.contribution }}</p>
      {% endif %}
      {% if project.tags %}
        <ul class="tag-list" aria-label="Technologies used for {{ project.title }}">
          {% for tag in project.tags %}
            <li>{{ tag }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      <div class="card-actions" aria-label="{{ project.title }} links">
        {% unless project.redirect -%}
          <a href="{{ project.url | relative_url }}">Project</a>
        {%- endunless %}
        {% if project.github -%}
          <a href="{{ project.github }}">GitHub</a>
        {%- endif %}
        {% if project.demo -%}
          <a href="{{ project.demo }}">Demo</a>
        {%- endif %}
        {% if project.redirect -%}
          <a href="{{ project.redirect }}">Visit project</a>
        {%- endif %}
      </div>
    </div>
  </article>
</div>
