<div class="col">
  <article class="card project-card h-100">
    {% if project.img %}
      {% assign image_class = 'card-img-top' %}
      {% if project.title == 'SCRIBE' or project.title == 'waveOrder' %}
        {% assign image_class = 'card-img-top project-card__image--contain' %}
      {% endif %}
      {% include figure.liquid loading="lazy" path=project.img sizes="(min-width: 768px) 520px, 100vw" alt=project.title class=image_class %}
    {% endif %}
    <div class="card-body">
      <h3 class="card-title">{{ project.title }}</h3>
      <p class="card-text">{{ project.description }}</p>
      {% if project.tags %}
        <ul class="tag-list" aria-label="Technologies used for {{ project.title }}">
          {% for tag in project.tags %}
            <li>{{ tag }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      <div class="card-actions" aria-label="{{ project.title }} links">
        {% unless project.redirect -%}
          <a href="{{ project.url | relative_url }}">Project</a>
        {%- endunless %}
        {% if project.github -%}
          <a href="{{ project.github }}">GitHub</a>
        {%- endif %}
        {% if project.demo -%}
          <a href="{{ project.demo }}">Demo</a>
        {%- endif %}
        {% if project.redirect -%}
          <a href="{{ project.redirect }}">Visit project</a>
        {%- endif %}
      </div>
    </div>
  </article>
</div>
